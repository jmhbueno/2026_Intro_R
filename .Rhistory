link <- "https://raw.githubusercontent.com/jmhbueno/2026_Intro_R/main/imdb1000.rds"
# Importar o arquivo do githug para o computador (fora do R)
download.file(                # função da base para importar arquivos da internet
url = link,                 # informar a url do arquivo, chamando o objeto link
destfile = "imdb1000.rds",  # dizer o nome que eu quero dar ao arquivo
mode = "wb")                # informação técnica sobre o tipo do arquivo (binário)
# Importar o arquivo salvo no computador (na pasta do projeto), para dentro do R.
imdb1000 <- readRDS("imdb1000.rds")
