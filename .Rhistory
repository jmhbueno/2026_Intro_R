tabela_apa <- tabela_apa |>
font(fontname = "Times New Roman", part = "all") |>
fontsize(size = 12, part = "all") |>
align(align = "center", part = "header") |>
align(align = "left", part = "body") |>
border_remove() |>
hline_top(part = "all", border = fp_border(width = 1)) |>
hline(part = "header", border = fp_border(width = 1)) |>
hline_bottom(part = "body", border = fp_border(width = 1)) |>
autofit()
save_as_docx(
tabela_apa,
path = "atalhos_APA.docx"
)
