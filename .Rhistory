wp1[order(wp1$Country),]
wp[wp$Country == c("Brazil","China","Russia","India"),c(3,7,15:17)]
wp[wp$Country == c("Brazil"|"China"|"Russia"|"India"),c(3,7,15:17)]
wp[wp$Country %in% c("Brazil","China","Russia","India"),c(3,7,15:17)]
