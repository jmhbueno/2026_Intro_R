#| label: importar world_population
# criar um objeto com a url onde do arquivo
link_wp <- "https://raw.githubusercontent.com/jmhbueno/2026_Intro_R/main/world_population.csv"
# Importar o arquivo do githug para o computador (fora do R)
download.file(
url = link_wp,
destfile = "world_population.csv",
mode = "wb")
# Importar o arquivo salvo no computador (na pasta do projeto), para dentro do R.
wp <- read.csv("world_population.csv")
str(wp)
wp1 <- wp[wp$Continent == "South America",3:4]
print(wp1)
print(wp1) %>% as.data.frame()
print(wp1) %>% as.data.frame() %>% kable()
print(wp1) %>% as.data.frame() %>% kable()
wp1[order(wp1$Country),]
wp[wp$Country == c("Brazil","China","Russia","India"),c(3,7,15:17)]
wp[wp$Country == c("Brazil"|"China"|"Russia"|"India"),c(3,7,15:17)]
wp[wp$Country %in% c("Brazil","China","Russia","India"),c(3,7,15:17)]
