# Separar a variável gênero em três variáveis (Genre1, Genre2 e Genre3)
imdb1000 <-
imdb1000 %>%
separate(Genre, sep = ",", into = c("Genre1","Genre2","Genre3"))
str(imdb1000)
saveRDS(imdb1000,"imdb1000.rds")
download.file(url = url, destfile = "imdb1000_git.rds", mode = "wb")
imdb1000 <- readRDS("imdb1000_git.rds")
