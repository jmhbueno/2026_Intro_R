str(imdb1000)
download.file(url = url, destfile = "imdb1000.rds", mode = "wb")
imdb1000 <- readRDS("imdb1000.rds")
#| label: ex2.1
str(imdb1000)
nrow(imdb1000)
ncol(imdb1000)
#| label: ex2.2
imdb1000[imdb1000$Director == "Woody Allen",c("Series_Title","Director")]
#| label: ex2.3
imdb1000[imdb1000$Director == "Steven Spielberg" & imdb1000$Released_Year <= 2000,
c("Released_Year","Director","Series_Title")]
#| label: ex2.4
imdb1000[(imdb1000$Director == "James Cameron" | imdb1000$Director == "Steven Spielberg") & (imdb1000$Genre1 == "Drama" | imdb1000$Genre1 == "Action"), ]
